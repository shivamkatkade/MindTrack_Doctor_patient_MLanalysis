<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Last 7 Days Analysis Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your Last 7 Days Analysis"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Image for Last 7 Days Analysis -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/imgLast7Days"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="#E0E0E0"
                android:adjustViewBounds="true"
                android:scaleType="fitStart"
                android:contentDescription="Last 7 Days Analysis"/>
        </androidx.cardview.widget.CardView>

        <!-- Suggestions Title -->
        <TextView
            android:id="@+id/tvSuggestionsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suggestions For You"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp"/>

        <!-- Suggestion 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvSuggestion1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Take short breaks during work to reduce stress."
                android:padding="12dp"
                android:textColor="#333333"
                android:textSize="16sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Suggestion 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvSuggestion2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Maintain a consistent sleep schedule for better energy."
                android:padding="12dp"
                android:textColor="#333333"
                android:textSize="16sp"/>
        </androidx.cardview.widget.CardView>

        <!-- Suggestion 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvSuggestion3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Engage in light physical activity daily to improve mood."
                android:padding="12dp"
                android:textColor="#333333"
                android:textSize="16sp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
